root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{cs,csproj,props,targets,sln,slnx,xml,json,yaml,yml,md}]
indent_size = 2

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[src/platform-core/SmartWarehouse.PlatformCore.Infrastructure/Persistence/Migrations/*.cs]
generated_code = true
