{
  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
  "OTEL_SERVICE_NAME": "platform-core",
  "OTEL_RESOURCE_ATTRIBUTES": "deployment.environment=development,site.id=local,service.version=0.1.0-dev",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "HealthChecks": {
    "Dependencies": {
      "Postgres": {
        "Enabled": true,
        "Host": "localhost",
        "Port": 5432,
        "TimeoutSeconds": 3
      },
      "Nats": {
        "Enabled": true,
        "Host": "localhost",
        "Port": 4222,
        "TimeoutSeconds": 3
      }
    }
  }
}
