{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartwarehouse.local/schemas/southbound/clear-fault-message.schema.json",
  "title": "ClearFaultMessage",
  "allOf": [
    {
      "$ref": "./base-message-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "messageType": {
          "const": "ClearFault"
        },
        "payload": {
          "type": "object",
          "required": [
            "faultCode"
          ],
          "properties": {
            "faultCode": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
