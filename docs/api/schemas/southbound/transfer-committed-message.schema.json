{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartwarehouse.local/schemas/southbound/transfer-committed-message.schema.json",
  "title": "TransferCommittedMessage",
  "allOf": [
    {
      "$ref": "./base-message-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "messageType": {
          "const": "TransferCommitted"
        },
        "payload": {
          "type": "object",
          "required": [
            "transferPointId"
          ],
          "properties": {
            "transferPointId": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
