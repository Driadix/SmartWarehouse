{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartwarehouse.local/schemas/southbound/transfer-ready-message.schema.json",
  "title": "TransferReadyMessage",
  "allOf": [
    {
      "$ref": "./base-message-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "messageType": {
          "const": "TransferReady"
        },
        "payload": {
          "type": "object",
          "required": [
            "transferPointId",
            "role"
          ],
          "properties": {
            "transferPointId": {
              "type": "string",
              "minLength": 1
            },
            "role": {
              "enum": [
                "SOURCE",
                "RECEIVER"
              ]
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
