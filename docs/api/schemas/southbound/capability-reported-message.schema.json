{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartwarehouse.local/schemas/southbound/capability-reported-message.schema.json",
  "title": "CapabilityReportedMessage",
  "allOf": [
    {
      "$ref": "./base-message-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "messageType": {
          "const": "CapabilityReported"
        },
        "payload": {
          "type": "object",
          "required": [
            "staticCapabilities",
            "activeCapabilities"
          ],
          "properties": {
            "staticCapabilities": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "activeCapabilities": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
