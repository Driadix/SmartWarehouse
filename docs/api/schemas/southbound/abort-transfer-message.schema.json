{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smartwarehouse.local/schemas/southbound/abort-transfer-message.schema.json",
  "title": "AbortTransferMessage",
  "allOf": [
    {
      "$ref": "./base-message-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "messageType": {
          "const": "AbortTransfer"
        },
        "family": {
          "enum": [
            "Shuttle3D",
            "HybridLift"
          ]
        },
        "payload": {
          "type": "object",
          "required": [
            "transferPointId",
            "reason"
          ],
          "properties": {
            "transferPointId": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
