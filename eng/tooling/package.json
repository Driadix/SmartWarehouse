{
  "name": "smartwarehouse-tooling",
  "private": true,
  "engines": {
    "node": ">=22.22.2 <23"
  },
  "scripts": {
    "build:knowledge-map": "node ./build-knowledge-map.mjs",
    "validate:examples": "node ./validate-examples.mjs",
    "validate:openapi:semantic": "node ./validate-openapi.mjs",
    "validate:openapi:lint": "spectral lint ../../docs/api/northbound/openapi-v0.yaml --ruleset ./spectral.yaml --fail-severity warn",
    "validate:openapi": "npm run validate:openapi:semantic && npm run validate:openapi:lint",
    "validate:asyncapi": "spectral lint ../../docs/api/southbound/asyncapi-v0.yaml --ruleset ./spectral.yaml --fail-severity warn",
    "validate:schemas": "node ./validate-schemas.mjs",
    "validate:contracts": "npm run validate:openapi && npm run validate:asyncapi && npm run validate:schemas && npm run validate:examples"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@stoplight/spectral-cli": "^6.15.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.8.3"
  }
}
